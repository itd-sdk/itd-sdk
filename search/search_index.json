{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"","title":"itd-sdk","text":"<p>SDK \u0434\u043b\u044f \u0440\u0430\u0431\u043e\u0442\u044b \u0441 \u0438\u0442\u0434.com</p>"},{"location":"#_1","title":"\u0410\u043b\u044c\u0442\u0435\u0440\u043d\u0430\u0442\u0438\u0432\u044b","text":"<ul> <li>aioitd</li> <li>ITDpy (\u0444\u043e\u0440\u043a)</li> <li>ITD-SDK-js (JS)</li> </ul>"},{"location":"auth/","title":"\u0410\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u044f","text":""},{"location":"auth/#_2","title":"\u0421\u043f\u043e\u0441\u043e\u0431\u044b \u0430\u0432\u0442\u043e\u0440\u0438\u0437\u0430\u0446\u0438\u0438","text":"<p>\u0427\u0442\u043e\u0431\u044b \u043f\u043e\u043b\u0443\u0447\u0438\u0442\u044c \u0434\u043e\u0441\u0442\u0443\u043f \u043a \u0430\u043a\u043a\u0430\u0443\u043d\u0442\u0443, \u043f\u043e\u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044f <code>access</code> \u0438\u043b\u0438 <code>refresh</code> token.</p> <ul> <li><code>access_token</code> - JWT \u0442\u043e\u043a\u0435\u043d, \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442 \u043e\u043a\u043e\u043b\u043e 15 \u043c\u0438\u043d\u0443\u0442, \u043e\u0431\u043d\u043e\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u043f\u0440\u0438 \u043f\u0435\u0440\u0435\u0437\u0430\u0433\u0440\u0443\u0437\u043a\u0435 \u0441\u0442\u0440\u0430\u043d\u0438\u0446\u044b.</li> <li><code>refresh_token</code> - \u0421\u043b\u0443\u0447\u0430\u0439\u043d\u0430\u044f \u0441\u0442\u0440\u043e\u043a\u0430, \u0434\u0435\u0439\u0441\u0442\u0432\u0443\u0435\u0442 \u0431\u043e\u043b\u0435\u0435 \u043c\u0435\u0441\u044f\u0446\u0430, \u043e\u0431\u043d\u043e\u0432\u043b\u044f\u0435\u0442\u0441\u044f \u043f\u0440\u0438 \u0432\u044b\u0445\u043e\u0434\u0435 \u0438 \u043f\u043e\u0432\u0442\u043e\u0440\u043d\u043e\u043c \u0432\u0445\u043e\u0434\u0435.</li> </ul> <p>\u041d\u0430\u0439\u0442\u0438 <code>access token</code> \u043c\u043e\u0436\u043d\u043e \u0432 \u043b\u044e\u0431\u043e\u043c \u0437\u0430\u043f\u0440\u043e\u0441\u0435 \u0432 DevTools (\u043e\u0442\u043a\u0440\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u043d\u0430\u0436\u0430\u0442\u0438\u0435\u043c <code>F12</code>) \u0432\u043e \u0432\u043a\u043b\u0430\u0434\u043a\u0435 <code>\u0421\u0435\u0442\u044c</code> / <code>Network</code>: </p> <p>\u041d\u0430\u0439\u0442\u0438 <code>refresh token</code> \u043c\u043e\u0436\u043d\u043e \u043d\u0430\u0439\u0442\u0438 \u0432 \u0437\u0430\u043f\u0440\u043e\u0441\u0435 <code>/auth/refresh</code>: </p> <p>Info</p> <p>\u0421\u0430\u043c\u043e\u0435 \u0433\u043b\u0430\u0432\u043d\u043e\u0435 - \"refresh token\". \u041e\u0441\u0442\u0430\u043b\u044c\u043d\u044b\u0435 \u043a\u0443\u043a\u0438 - DDoS Guard \u0438 \u042f\u043d\u0434\u0435\u043a\u0441 \u041c\u0435\u0442\u0440\u0438\u043a\u0430</p>"},{"location":"auth/#_3","title":"\u0418\u043d\u0438\u0446\u0438\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u044f","text":"refreshaccess <pre><code>from itd import ITDClient\n\nc = ITDClient(cookies='refresh_token=xxx')\n</code></pre> <pre><code>from itd import ITDClient\n\nc = ITDClient('eyXXX')\n</code></pre>"},{"location":"posts/","title":"\u041f\u043e\u0441\u0442\u044b","text":""},{"location":"posts/#_2","title":"\u0421\u043e\u0437\u0434\u0430\u0442\u044c \u043f\u043e\u0441\u0442","text":"<pre><code>c.create_post(\n    content='\u0447\u0438\u0435\u043d\u0431\u0443\u0440\u0431\u0435 \u043a\u0440\u0443\u0447\u0435 \u0447\u0435\u043c #\u0438\u0432\u0430\u043d\u0433\u043e\u0432\u043d\u043e',\n    spans=[],\n    wall_recipient_id=None,\n    attachemnt_ids=[],\n    poll=None\n)\n</code></pre>"},{"location":"posts/#_3","title":"\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b","text":""},{"location":"posts/#content","title":"content","text":"<p>\u0421\u043e\u0434\u0435\u0440\u0436\u0430\u043d\u0438\u0435 \u043f\u043e\u0441\u0442\u0430.</p>"},{"location":"posts/#spans","title":"spans","text":"<p>\u0421\u0442\u0438\u043b\u0438\u0437\u0430\u0446\u0438\u044f.</p> <p>Example</p> <p>\u0414\u043b\u044f \u043f\u043e\u043b\u0443\u0447\u0435\u043d\u0438\u044f \u044d\u0442\u043e\u0433\u043e \u0441\u043f\u0438\u0441\u043a\u0430 \u043c\u043e\u0436\u043d\u043e \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u0442\u044c \u043f\u0430\u0440\u0441\u0438\u043d\u0433 (\u043d\u0430 \u0434\u0430\u043d\u043d\u044b\u0439 \u043c\u043e\u043c\u0435\u043d\u0442 \u043f\u043e\u0434\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0435\u0442\u0441\u044f \u0442\u043e\u043b\u044c\u043a\u043e <code>html</code>):</p> <p><pre><code>from itd.utils import parse_html\n\nc.create_post(*parse_html('&lt;b&gt;\u0422\u043e\u043b\u0441\u0442\u044b\u0439&lt;/b&gt; &lt;i&gt;\u0438&lt;/i&gt; \u0442\u043e\u043d\u043a\u0438\u0439'))\n</code></pre> \u0420\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442: \u0442\u043e\u043b\u0441\u0442\u044b\u0439 \u0438 \u0442\u043e\u043d\u043a\u0438\u0439</p> <p>Info</p> <p><code>*</code> - \u0441\u0438\u043c\u0432\u043e\u043b \u0434\u043b\u044f \"\u0440\u0430\u0437\u0430\u0440\u0445\u0438\u0432\u0430\u0446\u0438\u0438\". <code>parse_html</code> \u0432\u043e\u0437\u0432\u0440\u0430\u0449\u0430\u0435\u0442 \u0441\u043f\u0438\u0441\u043e\u043a, \u043a\u043e\u0442\u043e\u0440\u044b\u0439 <code>*</code> \u0440\u0430\u0437\u0434\u0435\u043b\u044f\u0435\u0442 \u043d\u0430 <code>content</code> (\u0447\u0438\u0442\u044b\u0439 \u043a\u043e\u043d\u0442\u0435\u043d\u0442 \u0431\u0435\u0437 \u0442\u044d\u0433\u043e\u0432) \u0438 <code>spans</code></p>"},{"location":"posts/#wall_recipient_id","title":"wall_recipient_id","text":"<p>ID \u043f\u043e\u043b\u0443\u0447\u0430\u0442\u0435\u043b\u044f \u043f\u043e\u0441\u0442\u0430 (\u0434\u043b\u044f \u043f\u043e\u0441\u0442\u043e\u0432 \u043d\u0430 \u0441\u0442\u0435\u043d\u0435). <code>Username</code> \u043d\u0435 \u0440\u0430\u0431\u043e\u0442\u0430\u0435\u0442.</p>"},{"location":"posts/#attachment_ids","title":"attachment_ids","text":"<p>ID \u0432\u043b\u043e\u0436\u0435\u043d\u0438\u0439.</p>"},{"location":"posts/#poll","title":"poll","text":"<p>\u041e\u043f\u0440\u043e\u0441\u043d\u0438\u043a.</p> <p>Example</p> <pre><code>from itd.models.post import PollData\n\nc.create_post(\n    poll=PollData(\n        '\u0432\u0430\u043f\u0440\u043e', # (1)\n        ['\u043e\u0440\u0435\u0448\u043a\u0438 \u043c\u0430\u043a\u0430\u0434\u0430\u043c\u044c\u044f', '\u043c\u043d\u0435 \u043e\u0444\u0435\u043d\u044c \u043d\u0433\u0430\u0445\u0432\u044f\u0442\u0441\u044f'], # (2)\n        False # (3)\n    )\n)\n</code></pre> <ol> <li>\u0412\u043e\u043f\u0440\u043e\u0441 \u043e\u043f\u0440\u043e\u0441\u0430</li> <li>\u0412\u0430\u0440\u0438\u0430\u043d\u0442\u044b \u043e\u0442\u0432\u0435\u0442\u0430</li> <li>\u041c\u043e\u0436\u043d\u043e \u043b\u0438 \u043e\u0442\u0432\u0435\u0442\u0438\u0442\u044c \u0441\u0440\u0430\u0437\u0443 \u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u0432\u0430\u0440\u0438\u0430\u043d\u0442\u043e\u0432 (\u043f\u043e \u0443\u043c\u043e\u043b\u0447\u0430\u043d\u0438\u044e - <code>False</code>)</li> </ol>"},{"location":"posts/#_4","title":"\u041e\u0448\u0438\u0431\u043a\u0438","text":""},{"location":"posts/#notfound","title":"NotFound","text":"<p>\u041f\u043e\u043b\u0443\u0447\u0430\u0442\u0435\u043b\u044c \u043f\u043e\u0441\u0442\u0430 \u043d\u0435 \u043d\u0430\u0439\u0434\u0435\u043d.</p> <p>Example</p> <pre><code>c.create_post(\n    '123',\n    wall_recipient_id=UUID('6b791b8b-e8b7-41ee-8e12-1d48ca0b4cf0') # !\n)\n</code></pre>"},{"location":"posts/#forbidden","title":"Forbidden","text":"<p>\u041d\u0435\u043a\u043e\u0442\u043e\u0440\u044b\u0435 \u0432\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u043d\u0435 \u043f\u0440\u0438\u043d\u0430\u0434\u043b\u0435\u0436\u0430\u0442 \u0432\u0430\u043c \u0438\u043b\u0438 \u0444\u0430\u0439\u043b \u043d\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442. \u0412\u043b\u043e\u0436\u0435\u043d\u0438\u044f \u0434\u043e\u043b\u0436\u043d\u044b \u0431\u044b\u0442\u044c \u0437\u0430\u0433\u0440\u0443\u0436\u0435\u043d\u044b \u0432\u0430\u043c\u0438 \u0447\u0435\u0440\u0435\u0437 <code>upload_file</code>.</p> <p>Example</p> <pre><code>c.create_post(\n    attachment_ids=[UUID('6b791b8b-e8b7-41ee-8e12-1d48ca0b4cf2')] # !\n)\n</code></pre>"},{"location":"posts/#validationerror","title":"ValidationError","text":"<p>\u041e\u0448\u0438\u0431\u043a\u0430 \u0432\u0430\u043b\u0438\u0434\u0430\u0446\u0438\u0438, \u0441\u043a\u043e\u0440\u0435\u0435 \u0432\u0441\u0435\u0433\u043e \u0438\u0437-\u0437\u0430 \u0441\u043b\u0438\u0448\u043a\u043e\u043c \u0431\u043e\u043b\u044c\u0448\u043e\u0433\u043e \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u0430 \u0441\u0438\u043c\u0432\u043e\u043b\u043e\u0432.</p> <p>Example</p> <pre><code>c.create_post(\n    '\u0448\u043a\u0435\u0431\u0435\u0442\u043e\u0438\u043b\u0435\u0442' * 1000 # !\n)\n</code></pre>"},{"location":"posts/#videorequiresverification","title":"VideoRequiresVerification","text":"<p>\u0412\u043e\u0437\u043d\u0438\u043a\u0430\u0435\u0442 \u043f\u0440\u0438 \u043f\u043e\u043f\u044b\u0442\u043a\u0435 \u0437\u0430\u0433\u0440\u0443\u0437\u0438\u0442\u044c \u0432\u0438\u0434\u0435\u043e \u0441 \u043d\u0435\u0432\u0435\u0440\u0438\u0444\u0438\u0446\u0438\u0440\u043e\u0432\u0430\u043d\u043e\u0433\u043e \u0430\u043a\u043a\u0430\u0443\u043d\u0442\u0430.</p> <p>Example</p> <pre><code>c.create_post(\n    attachment_ids=[UUID('bc073a52-0d8a-4039-b33a-74b5a01b689f')] # !\n)\n</code></pre>"},{"location":"posts/#_5","title":"\u041f\u0440\u043e\u0433\u043e\u043b\u043e\u0441\u043e\u0432\u0430\u0442\u044c","text":"<pre><code>c.vote(\n    id=UUID('aa612e16-eb1f-4323-89ce-4eacda133672'),\n    option_ids=[UUID('f12c70c7-141e-4dff-9e5b-87f039c7ba58')]\n)\n</code></pre>"},{"location":"posts/#_6","title":"\u041f\u0430\u0440\u0430\u043c\u0435\u0442\u0440\u044b","text":""},{"location":"posts/#id","title":"id","text":"<p>ID \u043f\u043e\u0441\u0442\u0430.</p>"},{"location":"posts/#option_ids","title":"option_ids","text":"<p>ID \u043e\u043f\u0446\u0438\u0439 \u0434\u043b\u044f \u0432\u044b\u0431\u043e\u0440\u0430 (\u0434\u0430\u0436\u0435 \u0435\u0441\u043b\u0438 \u0432 \u043e\u043f\u0440\u043e\u0441\u0435 \u043c\u043e\u0436\u043d\u043e \u0432\u044b\u0431\u0440\u0430\u0442\u044c \u0442\u043e\u043b\u044c\u043a\u043e 1 \u0432\u0430\u0440\u0438\u0430\u043d\u0442, \u0432\u0441\u0435 \u0440\u0430\u0432\u043d\u043e \u043f\u0438\u0448\u0438\u0442\u0435 \u043a\u0430\u043a \u0441\u043f\u0438\u0441\u043e\u043a).</p> <p>Example</p> 1 \u043e\u043f\u0446\u0438\u044f\u043d\u0435\u0441\u043a\u043e\u043b\u044c\u043a\u043e \u043e\u043f\u0446\u0438\u0439 <pre><code>c.vote(\n    UUID('aa612e16-eb1f-4323-89ce-4eacda133672'),\n    [UUID('f12c70c7-141e-4dff-9e5b-87f039c7ba58')]\n)\n</code></pre> <pre><code>c.vote(\n    UUID('a6135f23-bd75-441b-93b7-cf9cf04ef76c'),\n    [\n        UUID('6daf7815-b30a-4f98-8091-7a0e24caba6c'),\n        UUID('3add69ee-4dae-4a81-9e4a-3e0fe77c7be0'),\n        UUID('ac758a37-2cb5-45ba-b743-a0a11a2b8d3d')\n    ]\n)\n</code></pre>"},{"location":"posts/#_7","title":"\u041f\u043e\u0441\u0442\u044b","text":""}]}